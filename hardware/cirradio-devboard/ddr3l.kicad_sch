    (text "ROUTING NOTES:" (at 30 380 0) (effects (font (size 2.0 2.0))))
    (text "1. Fly-by topology: Zynq -> U_DDR0 -> U_DDR1 for address/command/clock" (at 30 386 0) (effects (font (size 1.27 1.27))))
    (text "2. Match DQ/DQS trace lengths within each byte lane (+/- 5 mil)" (at 30 390 0) (effects (font (size 1.27 1.27))))
    (text "3. Match DQS-to-CK skew within each chip (+/- 10 mil)" (at 30 394 0) (effects (font (size 1.27 1.27))))
    (text "4. CK/CK# and DQS/DQS# are 100-ohm differential pairs" (at 30 398 0) (effects (font (size 1.27 1.27))))
    (text "5. Single-ended impedance target: 40 ohm (DDR3L)" (at 30 402 0) (effects (font (size 1.27 1.27))))
    (text "6. Differential impedance target: 80 ohm" (at 30 406 0) (effects (font (size 1.27 1.27))))
    (text "7. Place decoupling caps within 2mm of BGA balls" (at 30 410 0) (effects (font (size 1.27 1.27))))
    (text "8. ZQ resistor: 240R 1% tolerance, place within 5mm of ZQ ball" (at 30 414 0) (effects (font (size 1.27 1.27))))
    (text "9. VREFDQ divider: place within 10mm of VREFDQ ball" (at 30 418 0) (effects (font (size 1.27 1.27))))
    (text "10. VTT termination resistors at far end of fly-by (after U_DDR1)" (at 30 422 0) (effects (font (size 1.27 1.27))))
)